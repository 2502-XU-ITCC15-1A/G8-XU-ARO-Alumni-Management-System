{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://YOUR_RENDER_APP.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://YOUR_RENDER_APP.onrender.com/uploads/:path*"
    },
    {
      "source": "/((?!api|uploads).*)",
      "destination": "/index.html"
    }
  ]
}
